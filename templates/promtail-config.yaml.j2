server:
  http_listen_port: 9081
  grpc_listen_port: 0

positions:
  filename: C:\TaurisIT\promtail\positions.yaml

clients:
  - url: http://10.60.20.85:3100/loki/api/v1/push

scrape_configs:
  - job_name: windows_events_application
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\TaurisIT\promtail\bookmark_application.xml
      eventlog_name: "Application"
      xpath_query: "*"
      labels:
        job: windows_events_application
        host: {{ ansible_facts["hostname"] }}
    pipeline_stages:
      - json:
          expressions:
            level: levelText
      - labels:
          level:

  - job_name: windows_events_system
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\TaurisIT\promtail\bookmark_system.xml
      eventlog_name: "System"
      xpath_query: "*"
      labels:
        job: windows_events_system
        host: {{ ansible_facts["hostname"] }}

  - job_name: taurisit_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: taurisit_logs
          host: {{ ansible_facts["hostname"] }}
          __path__: C:\TaurisIT\Log\*.log

  - job_name: windows_events_security
    windows_events:
      use_incoming_timestamp: true
      bookmark_path: C:\TaurisIT\promtail\bookmark_security.xml
      eventlog_name: "Security"
      xpath_query: "*"
      labels:
        job: windows_events_security
        host: {{ ansible_facts["hostname"] }}
