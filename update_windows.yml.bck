---
- name: Automatizácia inštalácie Windows aktualizácií
  hosts: windows
  # Rolling updates: Aktualizuje maximálne 5 serverov naraz, kým prejde na ďalšie
  serial: 5 
  tasks:
    - name: Vyhľadanie a inštalácia bezpečnostných a kritických aktualizácií
      win_updates:
        category_names:
          - SecurityUpdates
          - CriticalUpdates
        reboot: yes
        state: installed
